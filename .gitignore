# ===================================
# UDG Sentinel — .gitignore raíz
# ===================================

# Entorno y secretos
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
auth.json

# Dependencias
/backend/vendor/
/backend/node_modules/
node_modules/

# Builds
/backend/public/build/
/backend/public/hot/
/backend/public/storage/

# Laravel cache y storage temporal
/backend/storage/app/private/
/backend/storage/framework/cache/
/backend/storage/framework/sessions/
/backend/storage/framework/testing/
/backend/storage/framework/views/
/backend/storage/logs/
/backend/storage/*.key
/backend/storage/pail/
/backend/bootstrap/cache/*.php

# SQLite (solo para desarrollo local si se usa)
/backend/database/database.sqlite

# PHP análisis estático
/backend/.phpunit.cache
/backend/.phpunit.result.cache
/backend/.phpactor.json

# IDE y editores
.idea/
.fleet/
.nova/
.zed/
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
.DS_Store

# Docker
/infrastructure/production/.env
/infrastructure/docker/.env

# Collectors Python
collectors/__pycache__/
collectors/*.pyc
collectors/.venv/
collectors/venv/
collectors/.env

# Scripts
scripts/*.log

# Logs
*.log
npm-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing
/coverage/
/.nyc_output/

# Reportes generados
/backend/storage/app/reports/

# Temporales
*.tmp
*.temp
