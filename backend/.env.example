APP_NAME="UDG Sentinel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ──────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# BASE DE DATOS — MySQL
# ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=udg_sentinel
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────────────
# SESIONES
# ──────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ──────────────────────────────────────────────
# CACHE
# ──────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=sentinel_

# ──────────────────────────────────────────────
# COLAS (Queue)
# ──────────────────────────────────────────────
QUEUE_CONNECTION=redis

# Colas del pipeline de monitoreo
SENTINEL_QUEUE_UPTIME=monitoring-uptime
SENTINEL_QUEUE_SSL=monitoring-ssl
SENTINEL_QUEUE_TECH=monitoring-tech
SENTINEL_QUEUE_HEADERS=monitoring-headers
SENTINEL_QUEUE_ALERTS=monitoring-alerts

# ──────────────────────────────────────────────
# BROADCAST (WebSockets - tiempo real)
# ──────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local

# ──────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ──────────────────────────────────────────────
# CORREO
# ──────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.udg.mx
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="sentinel@udg.mx"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────
# AWS S3 (almacenamiento de reportes en producción)
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ──────────────────────────────────────────────
# HORIZON (Monitor de colas)
# ──────────────────────────────────────────────
HORIZON_ENABLED=true

# ──────────────────────────────────────────────
# SENTINEL — Configuración de motores
# ──────────────────────────────────────────────

# Intervalo de chequeo HTTP en minutos (default: 5)
SENTINEL_CHECK_INTERVAL=5

# Intervalo de escaneo SSL en horas (default: 24)
SENTINEL_SSL_SCAN_INTERVAL=24

# Intervalo de escaneo tecnológico en horas (default: 24)
SENTINEL_TECH_SCAN_INTERVAL=24

# Intervalo de escaneo de seguridad en horas (default: 12)
SENTINEL_SECURITY_SCAN_INTERVAL=12

# Intervalo del Discovery Engine en horas (default: 6)
SENTINEL_DISCOVERY_INTERVAL=6

# Timeout para solicitudes HTTP en segundos
SENTINEL_HTTP_TIMEOUT=10

# User-Agent para los recolectores
SENTINEL_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# Dominio raíz a monitorear
SENTINEL_ROOT_DOMAIN=udg.mx

# Días de anticipación para alertas SSL
SENTINEL_SSL_ALERT_DAYS_CRITICAL=7
SENTINEL_SSL_ALERT_DAYS_WARNING=30

# ──────────────────────────────────────────────
# NOTIFICACIONES
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

SLACK_BOT_TOKEN=
SLACK_CHANNEL=

TEAMS_WEBHOOK_URL=

# ──────────────────────────────────────────────
# SEGURIDAD
# ──────────────────────────────────────────────
AUTH_MAX_LOGIN_ATTEMPTS=10
AUTH_LOCKOUT_MINUTES=60
AUTH_FORCE_2FA=false

# ──────────────────────────────────────────────
# TELESCOPE (solo en desarrollo)
# ──────────────────────────────────────────────
TELESCOPE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
